PORT=5000
# The Vercel frontend URL (comma-separate multiple origins for CORS, e.g. production + localhost)
FRONTEND_URL=http://localhost:3000
# The public base URL used in QR codes — points to the FRONTEND on production
# e.g. PUBLIC_URL=https://your-app.vercel.app
PUBLIC_URL=http://localhost:3000
JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=12h
# Optional: Override data directory (must be writable). Useful for platforms with read-only app directories (e.g., Render)
# DATA_DIR=/tmp/data

# ── Frontend (Vite) env vars — set these in Vercel project settings ──────────
# Full URL to backend /api — e.g. https://certportal-api.onrender.com/api
# Leave unset in local dev (Vite proxy handles it automatically)
# VITE_API_URL=https://certportal-api.onrender.com/api
